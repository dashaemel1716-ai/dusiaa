<style>
:root{
  --bg:#FBF9F3; --cream:#EFE9DB; --cream-2:#F4EFE4; --card:#FFFFFF;
  --sage:#7E9A7B; --sage-700:#5E7A5C; --sage-900:#37492F;
  --olive:#9AA15F; --ink:#454539; --muted:#7C7C70; --border:#E6DECF;
  --shadow:0 18px 50px -28px rgba(55,73,47,.45);
  --shadow-sm:0 10px 30px -20px rgba(55,73,47,.4);
  --radius:26px; --radius-sm:18px;
  --wrap:1180px;
  --ff:'Manrope',system-ui,sans-serif;
  --serif:'Fraunces',Georgia,serif;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;font-family:var(--ff);color:var(--ink);background:var(--bg);
  line-height:1.7;font-size:17px;-webkit-font-smoothing:antialiased;overflow-x:hidden;
}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
h1,h2,h3{color:var(--sage-900);line-height:1.12;letter-spacing:-.02em;margin:0;font-weight:800}
p{margin:0 0 1em}
.wrap{max-width:var(--wrap);margin:0 auto;padding:0 24px}
.section{padding-block:clamp(64px,8vw,116px)}
.eyebrow{font-size:.74rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--sage-700);display:inline-flex;align-items:center;gap:.55em;margin:0 0 18px}
.eyebrow .leaf{width:18px;height:18px;color:var(--sage)}
.h2{font-size:clamp(1.85rem,3.6vw,2.7rem)}
.lead{font-size:1.12rem;color:var(--muted);max-width:62ch}
.serif{font-family:var(--serif)}

/* botanical sprig decorations */
.sprig{position:absolute;color:var(--sage);opacity:.22;pointer-events:none;z-index:0}

/* ---------- header ---------- */
header{position:sticky;top:0;z-index:50;backdrop-filter:blur(14px);
  background:rgba(251,249,243,.78);border-bottom:1px solid rgba(230,222,207,.7)}
.nav{display:flex;align-items:center;justify-content:space-between;gap:34px;height:74px}
.brand{display:flex;align-items:center;gap:12px;font-weight:800;color:var(--sage-900);font-size:1.02rem;letter-spacing:-.01em}
.brand .owl{width:38px;height:38px;flex:none;color:var(--sage-700)}
.brand small{display:block;font-weight:600;font-size:.72rem;letter-spacing:.04em;color:var(--muted);text-transform:uppercase}
.menu{display:flex;gap:26px;list-style:none;margin:0;padding:0;font-weight:600;font-size:.92rem}
.menu a{color:var(--ink);transition:color .2s;white-space:nowrap}
.menu a:hover{color:var(--sage-700)}
.nav-cta{display:flex;align-items:center;gap:16px}
.nav-phone{font-weight:800;color:var(--sage-900);white-space:nowrap}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:.5em;border:none;cursor:pointer;
  font-family:var(--ff);font-weight:700;font-size:.97rem;border-radius:999px;padding:14px 26px;transition:transform .2s,box-shadow .2s,background .2s;text-align:center}
.btn-primary{background:var(--sage-700);color:#fff;box-shadow:0 12px 30px -14px rgba(94,122,92,.9)}
.btn-primary:hover{background:var(--sage-900);transform:translateY(-2px)}
.btn-ghost{background:rgba(255,255,255,.7);color:var(--sage-900);border:1px solid var(--border)}
.btn-ghost:hover{background:#fff;transform:translateY(-2px)}
.burger{display:none;background:none;border:1px solid var(--border);border-radius:12px;width:46px;height:46px;cursor:pointer;color:var(--sage-900)}

/* ---------- hero ---------- */
.hero{position:relative;padding-top:clamp(40px,6vw,72px);padding-bottom:clamp(56px,7vw,96px);overflow:hidden}
.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(32px,5vw,72px);align-items:center}
.hero h1{font-size:clamp(2.3rem,4.6vw,3.85rem);margin:.35em 0 .55em}
.hero .lead{font-size:1.18rem;color:var(--ink)}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin:30px 0 30px}
.hero-mini{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px 24px;max-width:480px}
.hero-mini li{list-style:none;display:flex;align-items:center;gap:11px;font-weight:600;font-size:.96rem;color:var(--ink)}
.hero-mini .leaf{width:20px;height:20px;color:var(--sage);flex:none}
.hero-photo{position:relative}
.hero-photo .blob{position:absolute;inset:-6% -8% -10% 4%;background:linear-gradient(150deg,#E7EDE2,#DCE6D6);border-radius:46% 54% 58% 42%/52% 44% 56% 48%;z-index:0}
.hero-photo .frame{position:relative;z-index:1;border-radius:30px;overflow:hidden;box-shadow:var(--shadow);aspect-ratio:4/4.7;border:6px solid #fff}
.hero-photo .frame img{width:100%;height:100%;object-fit:cover;object-position:center top}
.namecard{position:absolute;z-index:2;left:-6px;bottom:26px;background:rgba(255,255,255,.82);backdrop-filter:blur(8px);
  border:1px solid rgba(255,255,255,.7);border-radius:18px;padding:14px 20px;box-shadow:var(--shadow-sm);max-width:230px}
.namecard b{display:block;font-family:var(--serif);font-weight:500;font-size:1.08rem;color:var(--sage-900);line-height:1.2}
.namecard span{font-size:.82rem;color:var(--muted);font-weight:600}
.exp-chip{position:absolute;z-index:2;right:-8px;top:34px;background:var(--sage-900);color:#fff;border-radius:20px;padding:14px 18px;text-align:center;box-shadow:var(--shadow)}
.exp-chip b{display:block;font-size:1.7rem;font-weight:800;line-height:1}
.exp-chip span{font-size:.72rem;letter-spacing:.04em;opacity:.85}

/* ---------- about ---------- */
.about-grid{display:grid;grid-template-columns:1fr 1.1fr;gap:clamp(32px,5vw,68px);align-items:center}
.about-img{position:relative}
.about-img img{border-radius:var(--radius);box-shadow:var(--shadow);width:100%;aspect-ratio:1/.82;object-fit:cover}
.about h2 .serif{font-style:italic;font-weight:500;display:block;font-size:1.15em;color:var(--sage-700);margin-bottom:.15em}
.about strong{color:var(--sage-900)}

/* ---------- services ---------- */
.bg-cream{background:linear-gradient(180deg,var(--cream-2),var(--cream))}
.head-center{text-align:center;max-width:720px;margin:0 auto 52px}
.head-center .lead{margin-inline:auto}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:34px 30px;
  box-shadow:var(--shadow-sm);transition:transform .3s,box-shadow .3s;position:relative;overflow:hidden}
.card:hover{transform:translateY(-6px);box-shadow:var(--shadow)}
.card .ic{width:54px;height:54px;border-radius:16px;display:grid;place-items:center;background:#EAF0E6;color:var(--sage-700);margin-bottom:20px}
.card .ic svg{width:28px;height:28px}
.card h3{font-size:1.22rem;margin-bottom:10px}
.card p{color:var(--muted);font-size:.99rem;margin:0}
.card ul{margin:.4em 0 0;padding:0;list-style:none;columns:2;column-gap:18px}
.card ul li{font-size:.95rem;color:var(--ink);padding:4px 0 4px 18px;position:relative;break-inside:avoid}
.card ul li::before{content:"";position:absolute;left:0;top:13px;width:7px;height:7px;border-radius:50%;background:var(--sage)}
.card.span2{grid-column:span 2}

/* ---------- programs / ebru ---------- */
.feature{display:grid;grid-template-columns:1.04fr 1fr;gap:clamp(30px,4vw,60px);align-items:center}
.feature.rev{direction:rtl}
.feature.rev>*{direction:ltr}
.feature-text h2{margin-bottom:18px}
.tag{display:inline-block;background:#EAF0E6;color:var(--sage-700);font-weight:700;font-size:.78rem;letter-spacing:.06em;text-transform:uppercase;padding:7px 15px;border-radius:999px;margin-bottom:18px}
.photo-pair{display:grid;grid-template-columns:1.3fr 1fr;grid-template-rows:auto auto;gap:16px}
.photo-pair img{border-radius:20px;box-shadow:var(--shadow-sm);width:100%;height:100%;object-fit:cover}
.photo-pair .tall{grid-row:span 2;aspect-ratio:auto}
.photo-pair .a{aspect-ratio:3/4}
.photo-pair .b{aspect-ratio:4/3}
.photo-pair .c{aspect-ratio:4/3}
.ebru-grid{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:196px;gap:16px}
.ebru-grid img{width:100%;height:100%;object-fit:cover;border-radius:20px;box-shadow:var(--shadow-sm)}
.ebru-grid .big{grid-row:span 2;grid-column:span 1}
.ebru-grid .wide{grid-column:span 2}

/* ---------- why choose ---------- */
.why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.why{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:26px 22px;text-align:left;box-shadow:var(--shadow-sm);transition:transform .25s}
.why:hover{transform:translateY(-4px)}
.why .ic{width:46px;height:46px;border-radius:14px;background:#EAF0E6;color:var(--sage-700);display:grid;place-items:center;margin-bottom:14px}
.why .ic svg{width:24px;height:24px}
.why b{display:block;color:var(--sage-900);font-size:1.02rem}

/* ---------- process ---------- */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:26px 30px;position:relative}
.step{position:relative;padding-left:6px}
.step .num{font-family:var(--serif);font-size:2.2rem;color:var(--sage);font-weight:500;line-height:1;display:flex;align-items:center;gap:12px;margin-bottom:12px}
.step .num .leaf{width:22px;height:22px;opacity:.8}
.step h3{font-size:1.12rem;margin-bottom:8px}
.step p{color:var(--muted);font-size:.97rem;margin:0}

/* ---------- gallery ---------- */
.gallery{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:200px;gap:16px}
.gallery figure{margin:0;overflow:hidden;border-radius:20px;box-shadow:var(--shadow-sm);position:relative}
.gallery img{width:100%;height:100%;object-fit:cover;transition:transform .6s ease}
.gallery figure:hover img{transform:scale(1.09)}
.gallery .t2{grid-row:span 2}
.gallery .w2{grid-column:span 2}

/* ---------- reviews ---------- */
.reviews{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.review{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:30px;box-shadow:var(--shadow-sm)}
.review .quote{font-family:var(--serif);font-size:2.6rem;color:var(--sage);line-height:.6;height:24px}
.review p{color:var(--ink);font-style:italic}
.review .who{display:flex;align-items:center;gap:12px;margin-top:18px;font-weight:700;color:var(--sage-900);font-style:normal;font-size:.95rem}
.review .av{width:42px;height:42px;border-radius:50%;background:#EAF0E6;color:var(--sage-700);display:grid;place-items:center;font-family:var(--serif);font-weight:600}
.review.add{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;border-style:dashed;background:transparent;color:var(--muted)}
.review.add .ic{width:46px;height:46px;border-radius:50%;background:#EAF0E6;color:var(--sage-700);display:grid;place-items:center;margin-bottom:12px}

/* ---------- contacts ---------- */
.contact-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:clamp(30px,4vw,56px);align-items:start}
.contact-card{background:var(--sage-900);color:#fff;border-radius:var(--radius);padding:clamp(30px,4vw,46px);position:relative;overflow:hidden}
.contact-card h2{color:#fff}
.contact-card .lead{color:rgba(255,255,255,.78)}
.phone-big{font-size:clamp(1.7rem,3vw,2.3rem);font-weight:800;letter-spacing:-.01em;margin:18px 0 22px;display:inline-block;color:#fff}
.contact-actions{display:flex;gap:12px;flex-wrap:wrap}
.contact-actions a{flex:1;min-width:120px;display:inline-flex;align-items:center;justify-content:center;gap:9px;padding:14px 16px;border-radius:14px;font-weight:700;font-size:.95rem;transition:transform .2s,background .2s}
.contact-actions a svg{width:20px;height:20px}
.wa{background:#fff;color:var(--sage-900)}
.tg{background:rgba(255,255,255,.14);color:#fff;border:1px solid rgba(255,255,255,.22)}
.cl{background:var(--olive);color:#fff}
.contact-actions a:hover{transform:translateY(-2px)}
.form{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:clamp(28px,3.5vw,40px);box-shadow:var(--shadow-sm)}
.form h3{font-size:1.4rem;margin-bottom:6px}
.form p.sub{color:var(--muted);font-size:.95rem;margin-bottom:22px}
.field{margin-bottom:16px}
.field label{display:block;font-weight:600;font-size:.88rem;color:var(--sage-900);margin-bottom:7px}
.field input,.field textarea{width:100%;font-family:var(--ff);font-size:1rem;color:var(--ink);background:var(--bg);
  border:1px solid var(--border);border-radius:14px;padding:14px 16px;transition:border .2s,box-shadow .2s}
.field textarea{resize:vertical;min-height:96px}
.field input:focus,.field textarea:focus{outline:none;border-color:var(--sage);box-shadow:0 0 0 4px rgba(126,154,123,.16)}
.form .btn-primary{width:100%;padding:16px}
.form-note{font-size:.8rem;color:var(--muted);margin-top:14px;text-align:center}
.form-ok{display:none;background:#EAF0E6;border:1px solid var(--sage);color:var(--sage-900);border-radius:14px;padding:14px 16px;font-weight:600;font-size:.95rem;margin-bottom:16px}

/* ---------- footer ---------- */
footer{background:var(--cream);border-top:1px solid var(--border);padding:46px 0 36px}
.foot{display:flex;flex-wrap:wrap;gap:18px 36px;align-items:center;justify-content:space-between}
.foot .brand{font-size:.98rem}
.foot-links{display:flex;gap:24px;flex-wrap:wrap;font-size:.9rem;color:var(--muted)}
.foot-links a:hover{color:var(--sage-700)}
.copy{width:100%;border-top:1px solid var(--border);margin-top:30px;padding-top:22px;font-size:.85rem;color:var(--muted);text-align:center}

/* ---------- reveal ---------- */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .8s cubic-bezier(.2,.7,.2,1),transform .8s cubic-bezier(.2,.7,.2,1)}
.reveal.in{opacity:1;transform:none}

/* ---------- responsive ---------- */
@media(max-width:980px){
  .menu,.nav-phone{display:none}
  .burger{display:grid;place-items:center}
  .hero-grid,.about-grid,.feature,.contact-grid{grid-template-columns:1fr}
  .feature.rev{direction:ltr}
  .about-img{order:-1}
  .cards,.reviews{grid-template-columns:1fr 1fr}
  .card.span2{grid-column:span 2}
  .why-grid{grid-template-columns:1fr 1fr}
  .steps{grid-template-columns:1fr 1fr}
  .gallery{grid-template-columns:1fr 1fr;grid-auto-rows:180px}
  .ebru-grid{grid-auto-rows:150px}
  .mobile-menu.open{display:flex}
}
@media(max-width:560px){
  body{font-size:16px}
  .cards,.reviews,.why-grid,.steps,.gallery,.ebru-grid{grid-template-columns:1fr}
  .card.span2{grid-column:auto}
  .card ul{columns:1}
  .gallery{grid-auto-rows:220px}
  .gallery .w2,.gallery .t2{grid-column:auto;grid-row:auto}
  .ebru-grid .big,.ebru-grid .wide{grid-column:auto;grid-row:auto}
  .hero-mini{grid-template-columns:1fr}
  .photo-pair{grid-template-columns:1fr 1fr}
  .namecard{left:8px;bottom:12px}
}
.mobile-menu{display:none;position:fixed;inset:74px 0 auto 0;background:var(--bg);border-bottom:1px solid var(--border);
  flex-direction:column;padding:18px 24px 26px;gap:6px;z-index:49;box-shadow:var(--shadow-sm)}
.mobile-menu a{padding:12px 4px;font-weight:600;border-bottom:1px solid var(--border)}
.mobile-menu .btn-primary{margin-top:14px}

@media(prefers-reduced-motion:reduce){
  *{scroll-behavior:auto!important}
  .reveal{opacity:1;transform:none;transition:none}
  .gallery img,.card,.why,.btn{transition:none}
}
</style>
</head>
